# ============================================
# GitTy - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# On Vercel: Add these in Project Settings > Environment Variables

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Midtrans Configuration ---
MIDTRANS_SERVER_KEY=your-server-key-here
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-client-key-here

# --- Midtrans Price IDs ---
MIDTRANS_PRICE_PRO=price_pro_monthly_id
MIDTRANS_PRICE_TEAM=price_team_monthly_id
MIDTRANS_PRICE_ENTERPRISE=price_enterprise_monthly_id

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- Claude (Optional) ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- Gemini (Optional) ---
GOOGLE_AI_API_KEY=your-google-ai-key

# --- App Config ---
NEXT_PUBLIC_APP_NAME=GitTy
NEXT_PUBLIC_APP_URL=http://localhost:3000
